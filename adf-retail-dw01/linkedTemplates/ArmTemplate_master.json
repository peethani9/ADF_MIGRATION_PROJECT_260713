{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-retail-dw01"
		},
		"ADLS_SQL_PARQUET_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS_SQL_PARQUET'"
		},
		"LS_ONPrem_SqlServer_DW_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_ONPrem_SqlServer_DW'"
		},
		"LS_Parent_SqlServer_DW_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_Parent_SqlServer_DW'"
		},
		"LS_SQLSERVER_TBLLKUP_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQLSERVER_TBLLKUP'"
		},
		"ADLS_SQL_PARQUET_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stretaildw1.dfs.core.windows.net/"
		},
		"LS_ONPrem_SqlServer_DW_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "BHAVYA\\SQLEXPRESS"
		},
		"LS_ONPrem_SqlServer_DW_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "RetailDW_Dev"
		},
		"LS_ONPrem_SqlServer_DW_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "BHAVYA"
		},
		"LS_Parent_SqlServer_DW_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "BHAVYA\\SQLEXPRESS"
		},
		"LS_Parent_SqlServer_DW_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "RetailDW_Dev"
		},
		"LS_Parent_SqlServer_DW_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "BHAVYA"
		},
		"LS_SQLSERVER_TBLLKUP_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "BHAVYA\\SQLEXPRESS"
		},
		"LS_SQLSERVER_TBLLKUP_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "RetailDW_Dev"
		},
		"LS_SQLSERVER_TBLLKUP_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "BHAVYA"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-retail-dw01_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLS_SQL_PARQUET_accountKey": {
						"value": "[parameters('ADLS_SQL_PARQUET_accountKey')]"
					},
					"LS_ONPrem_SqlServer_DW_password": {
						"value": "[parameters('LS_ONPrem_SqlServer_DW_password')]"
					},
					"LS_Parent_SqlServer_DW_password": {
						"value": "[parameters('LS_Parent_SqlServer_DW_password')]"
					},
					"LS_SQLSERVER_TBLLKUP_password": {
						"value": "[parameters('LS_SQLSERVER_TBLLKUP_password')]"
					},
					"ADLS_SQL_PARQUET_properties_typeProperties_url": {
						"value": "[parameters('ADLS_SQL_PARQUET_properties_typeProperties_url')]"
					},
					"LS_ONPrem_SqlServer_DW_properties_typeProperties_server": {
						"value": "[parameters('LS_ONPrem_SqlServer_DW_properties_typeProperties_server')]"
					},
					"LS_ONPrem_SqlServer_DW_properties_typeProperties_database": {
						"value": "[parameters('LS_ONPrem_SqlServer_DW_properties_typeProperties_database')]"
					},
					"LS_ONPrem_SqlServer_DW_properties_typeProperties_userName": {
						"value": "[parameters('LS_ONPrem_SqlServer_DW_properties_typeProperties_userName')]"
					},
					"LS_Parent_SqlServer_DW_properties_typeProperties_server": {
						"value": "[parameters('LS_Parent_SqlServer_DW_properties_typeProperties_server')]"
					},
					"LS_Parent_SqlServer_DW_properties_typeProperties_database": {
						"value": "[parameters('LS_Parent_SqlServer_DW_properties_typeProperties_database')]"
					},
					"LS_Parent_SqlServer_DW_properties_typeProperties_userName": {
						"value": "[parameters('LS_Parent_SqlServer_DW_properties_typeProperties_userName')]"
					},
					"LS_SQLSERVER_TBLLKUP_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLSERVER_TBLLKUP_properties_typeProperties_server')]"
					},
					"LS_SQLSERVER_TBLLKUP_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLSERVER_TBLLKUP_properties_typeProperties_database')]"
					},
					"LS_SQLSERVER_TBLLKUP_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLSERVER_TBLLKUP_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}